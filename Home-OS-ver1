function renderHome(){
  const h=new Date().getHours();
  const g=h<11?'Selamat pagi,':h<15?'Selamat siang,':h<18?'Selamat sore,':'Selamat malam,';
  document.getElementById('greeting-text').textContent=g;
  document.getElementById('greeting-name').textContent=APP.profile.name1+' & '+APP.profile.name2;
  document.getElementById('home-avatar').textContent=(APP.profile.name1[0]||'N')+(APP.profile.name2[0]||'A');
