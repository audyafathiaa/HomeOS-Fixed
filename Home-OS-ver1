let docFilter='semua';

function initDefaultDocs(){
  // Only if empty
  if(APP.dokumen.length > 0) return;
  Object.keys(DOC_DEFAULT).forEach(cat=>{
    DOC_DEFAULT[cat].forEach(name=>{
      APP.dokumen.push({name, cat, who:'Bersama', status:'unknown', exp:null, note:'', isDefault:true});
    });
  });
  save();
}

function renderDoc(f){
  initDefaultDocs();
  docFilter = f;
  const list = f==='semua' ? APP.dokumen : APP.dokumen.filter(d=>d.cat===f);
  const el = document.getElementById('doc-list');

  if(list.length === 0){
    el.innerHTML=`<div class="empty-state"><p>Tidak ada dokumen dengan filter ini.</p></div>`;
    return;
  }

  // Group by category if semua
  if(f === 'semua'){
    const groups = {};
    list.forEach(d=>{ if(!groups[d.cat]) groups[d.cat]=[]; groups[d.cat].push(d); });
    let html = '';
    Object.keys(groups).forEach(cat=>{
      html += `<div class="groc-section">${cat}</div>`;
      groups[cat].forEach(d=>{ html += docItemHTML(d, APP.dokumen.indexOf(d)); });
    });
    el.innerHTML = html;
  } else {
    el.innerHTML = list.map(d => docItemHTML(d, APP.dokumen.indexOf(d))).join('');
  }
}

function docItemHTML(d, ri){
  const st = d.status || 'unknown';
  const stConfig = {
    ada:     {bg:'#E5F7EF', col:'#4CAF8C', lbl:'Ada'},
    tidak:   {bg:'#FFE5E5', col:'#E05C5C', lbl:'Tidak Ada'},
    unknown: {bg:'var(--bg)', col:'var(--text-light)', lbl:'Belum Dicek'},
  };
  const cfg = stConfig[st] || stConfig['unknown'];
  
  // Check expired
  const dDays = d.exp ? daysDiff(d.exp) : null;
  const expBadge = dDays!==null ? (dDays<=0 ? `<span style="font-size:10px;font-weight:700;color:var(--accent-red);">Expired!</span>` : dDays<=30 ? `<span style="font-size:10px;font-weight:700;color:var(--accent-orange);">${dDays}h lagi</span>` : `<span style="font-size:10px;color:var(--text-light);">${fDateShort(d.exp)}</span>`) : '';

  return `<div style="background:var(--card);border-radius:13px;padding:12px 14px;margin-bottom:7px;box-shadow:var(--shadow-card);">
