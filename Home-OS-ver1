function deleteBatchRow(i){ batchRows.splice(i,1); renderBatchRows(); }

function updateBatchRow(i, field, val){ batchRows[i][field] = val; updateBatchTotal(); }

function updateBatchTotal(){
  const total = batchRows.reduce((s,r) => s + (parseFloat(r.harga)||0), 0);
  const count = batchRows.filter(r=>r.name.trim()).length;
  document.getElementById('batch-total-harga').textContent = fRp(total);
