function generateListBelanja(){
  const beliItems = APP.groceries.filter(g => g.status === 'beli' || g.status === 'habis' || g.status === 'hampir');
  if(beliItems.length === 0){ showToast('Tidak ada item yang ditandai Beli'); return; }
  const groups = {};
  beliItems.forEach(g=>{
    const cat = g.masterCat || g.cat || 'Lainnya';
    if(!groups[cat]) groups[cat]=[];
    groups[cat].push(g);
  });
  const now = new Date();
  let txt = `List Belanja — ${now.toLocaleDateString('id-ID',{day:'numeric',month:'long',year:'numeric'})}\n\n`;
  Object.keys(groups).forEach(cat=>{
    txt += `${cat}:\n`;
    groups[cat].forEach(g=>{ txt += `- ${g.name}${g.brand?' ('+g.brand+')':''}\n`; });
    txt += '\n';
  });
  document.getElementById('lb-text').textContent = txt;
  document.getElementById('modal-lb').classList.add('active');
  APP.lastOpname = new Date().toISOString();
  save();
}
function copyLB(){ const t=document.getElementById('lb-text').textContent; navigator.clipboard.writeText(t).then(()=>showToast('Berhasil dicopy!')).catch(()=>showToast('Coba copy manual')); }

// Custom item add (from + button)
function showAddGroceryModal(){
  document.getElementById('grocery-name').value='';
  document.getElementById('grocery-brand').value='';
  document.getElementById('grocery-status').value='beli';
  delete document.getElementById('modal-grocery').dataset.editIdx;
  document.getElementById('grocery-modal-title').textContent='Tambah Item Custom';
  document.getElementById('grocery-delete-btn').style.display='none';
  document.getElementById('modal-grocery').classList.add('active');
}

function editGrocery(i){
  const g=APP.groceries[i];
  document.getElementById('grocery-name').value=g.name;
  document.getElementById('grocery-cat').value=g.cat||g.masterCat||'Bahan Pokok';
  document.getElementById('grocery-status').value=g.status==='ada'?'cukup':g.status==='beli'?'habis':g.status||'cukup';
  document.getElementById('grocery-brand').value=g.brand||'';
  document.getElementById('modal-grocery').dataset.editIdx=i;
  document.getElementById('grocery-modal-title').textContent='Edit Item';
  document.getElementById('grocery-delete-btn').style.display='block';
  document.getElementById('modal-grocery').classList.add('active');
}

function saveGrocery(){
  const name=document.getElementById('grocery-name').value.trim();
  if(!name){showToast('Isi nama item');return;}
  const rawStatus=document.getElementById('grocery-status').value;
  const status = rawStatus==='cukup'?'ada': rawStatus==='habis'?'beli': rawStatus==='hampir'?'beli': rawStatus;
  const item={name, cat:document.getElementById('grocery-cat').value, masterCat:document.getElementById('grocery-cat').value, status, brand:document.getElementById('grocery-brand').value.trim(), isCustom:true};
  const ei=document.getElementById('modal-grocery').dataset.editIdx;
  if(ei!==undefined) APP.groceries[parseInt(ei)]=item; else APP.groceries.push(item);
  save(); closeModal('modal-grocery'); showToast('Item tersimpan'); renderGroceries();
}

function deleteGrocery(){
  const ei=document.getElementById('modal-grocery').dataset.editIdx;
  if(ei===undefined)return;
  if(!confirm('Hapus item ini?'))return;
  APP.groceries.splice(parseInt(ei),1);
  save(); closeModal('modal-grocery'); showToast('Item dihapus'); renderGroceries();
}

function resetGroceries(){
  if(!confirm('Reset semua status stok? Data akan kembali ke default.'))return;
  APP.groceries=[];
  save(); renderGroceries(); showToast('Stok direset');
}


