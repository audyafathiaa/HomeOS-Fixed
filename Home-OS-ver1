function renderEnergi(){
  const el=document.getElementById('energi-content');
  if(APP.energi.length===0){el.innerHTML=`<div class="empty-state"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg><p>Belum ada data utilitas. Tap + untuk tambah.</p></div>`;return;}
  // group by jenis, show last 3 months each
  const groups={};APP.energi.forEach(e=>{if(!groups[e.jenis])groups[e.jenis]=[];groups[e.jenis].push(e);});
  let html='';
  Object.keys(groups).forEach(jenis=>{
    const items=groups[jenis].slice().sort((a,b)=>b.bulan.localeCompare(a.bulan));
    const latest=items[0];
    const prev=items[1];
    const trend=prev?((latest.amount-prev.amount)/prev.amount*100):0;
    const tCls=trend>5?'trend-up':trend<-5?'trend-down':'trend-same';
    const tTxt=Math.abs(trend)<1?'Sama':trend>0?`+${trend.toFixed(0)}%`:`${trend.toFixed(0)}%`;
    html+=`<div class="energi-card"><div class="energi-row"><span class="energi-name">${jenis}</span><span class="energi-amount">${fRp(latest.amount)}</span></div><div style="display:flex;justify-content:space-between;align-items:center;"><span style="font-size:11px;color:var(--text-mid);">${latest.bulan}</span><span class="energi-trend ${tCls}">${tTxt} vs bulan lalu</span></div></div>`;
  });
  el.innerHTML=html;
}

