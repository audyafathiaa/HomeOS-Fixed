  const overdue=APP.chores.filter(c=>c.overdue).length;
  document.getElementById('stat-rem').textContent=APP.cicilan.length+APP.todos.filter(t=>t.status!=='done').length;
  document.getElementById('stat-groc').textContent=habis;
  document.getElementById('stat-over').textContent=overdue;
  // reminders
  const remEl=document.getElementById('home-reminders');
  const rems=buildReminders().slice(0,6);
  if(rems.length===0){remEl.innerHTML='<div style="font-size:13px;color:var(--text-light);padding:4px 2px;">Tidak ada reminder</div>';}
  else{remEl.innerHTML=rems.map(r=>`<div class="rem-card"><div class="rem-cat ${r.cls}">${r.cat}</div><h4>${r.title}</h4><p>${r.sub}</p>${r.amount?`<div class="rem-amount">${r.amount}</div>`:''}</div>`).join('');}
  // chores
  const choreEl=document.getElementById('home-chores');
  const daily=APP.chores.filter(c=>c.freq==='daily').slice(0,4);
  if(daily.length===0){choreEl.innerHTML='<div style="font-size:13px;color:var(--text-light);padding:4px 0;">Belum ada chores. Tambah di House Management.</div>';}
  else{choreEl.innerHTML=daily.map((c,i)=>choreItemHTML(c,APP.chores.indexOf(c),true)).join('');}
  // trx
  const trxEl=document.getElementById('home-trx');
  const recent=APP.transactions.slice().reverse().slice(0,5);
  if(recent.length===0){trxEl.innerHTML='<div style="font-size:13px;color:var(--text-light);padding:8px 0;">Belum ada transaksi. Tambah lewat tombol +</div>';}
  else{trxEl.innerHTML=recent.map(t=>trxHTML(t)).join('');}
}

function buildReminders(){
  const rems=[];
  // cicilan
  APP.cicilan.forEach(c=>{rems.push({cat:'Keuangan',cls:'fin',title:c.name,sub:'Cicilan ke-'+c.current+' dari '+c.total,amount:fRp(c.amount)+'/bln'});});
  // kendaraan pajak
  APP.kendaraan.forEach(k=>{
    if(k.pajak){const d=daysDiff(k.pajak);if(d!==null&&d<=60){rems.push({cat:'Kendaraan',cls:'veh',title:'Pajak '+k.name,sub:d<=0?'Sudah jatuh tempo!':d+' hari lagi',amount:null});}}
  });
  // dokumen expired
  APP.dokumen.forEach(doc=>{
    if(doc.exp){const d=daysDiff(doc.exp);if(d!==null&&d<=90){rems.push({cat:'Dokumen',cls:'doc',title:doc.name+' expiring',sub:d<=0?'Sudah expired!':d+' hari lagi',amount:null});}}
  });
  // garansi inventaris
  APP.inventaris.forEach(inv=>{
    if(inv.warranty){const d=daysDiff(inv.warranty);if(d!==null&&d<=30){rems.push({cat:'Garansi',cls:'doc',title:'Garansi '+inv.name,sub:d<=0?'Garansi habis!':d+' hari lagi',amount:null});}}
  });
  // todos urgent
  APP.todos.filter(t=>t.prio==='urgent'&&t.status!=='done').forEach(t=>{rems.push({cat:'To-Do',cls:'fin',title:t.name,sub:'Urgent'+(t.due?' · '+fDateShort(t.due):''),amount:null});});
  return rems;
}

