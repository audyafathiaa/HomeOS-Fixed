function saveTrx(){const desc=document.getElementById('trx-desc').value.trim();const amount=parseInt(document.getElementById('trx-amount').value);if(!desc||!amount){showToast('Isi deskripsi dan nominal');return;}APP.transactions.push({desc,amount,type:document.getElementById('trx-type').value,cat:document.getElementById('trx-cat').value,who:document.getElementById('trx-who').value,date:document.getElementById('trx-date').value||today()});save();closeModal('modal-trx');showToast('Transaksi tersimpan');renderFinance();}
function saveChore(){const name=document.getElementById('chore-name').value.trim();if(!name){showToast('Isi nama chore');return;}const item={name,freq:document.getElementById('chore-freq').value,assign:document.getElementById('chore-assign').value,lastDone:document.getElementById('chore-lastdone').value||null,overdue:false};const ei=document.getElementById('modal-chore').dataset.editIdx;if(ei!==undefined)APP.chores[parseInt(ei)]=item;else APP.chores.push(item);save();closeModal('modal-chore');showToast('Chore tersimpan');renderChores();}
function deleteChore(){const ei=document.getElementById('modal-chore').dataset.editIdx;if(ei===undefined)return;if(!confirm('Hapus chore ini?'))return;APP.chores.splice(parseInt(ei),1);save();closeModal('modal-chore');showToast('Chore dihapus');renderChores();}
function saveCicilan(){const name=document.getElementById('cic-name').value.trim();const amount=parseInt(document.getElementById('cic-amount').value);if(!name||!amount){showToast('Isi nama dan nominal');return;}const item={name,amount,total:parseInt(document.getElementById('cic-total').value)||12,current:parseInt(document.getElementById('cic-current').value)||1,lunas:document.getElementById('cic-lunas').value||'?'};const ei=document.getElementById('modal-cicilan').dataset.editIdx;if(ei!==undefined)APP.cicilan[parseInt(ei)]=item;else APP.cicilan.push(item);save();closeModal('modal-cicilan');showToast('Cicilan tersimpan');renderFinance();}
function deleteCicilan(){const ei=document.getElementById('modal-cicilan').dataset.editIdx;if(ei===undefined)return;if(!confirm('Hapus cicilan ini?'))return;APP.cicilan.splice(parseInt(ei),1);save();closeModal('modal-cicilan');showToast('Cicilan dihapus');renderFinance();}
function saveBudget(){const cat=document.getElementById('budget-cat').value;const amount=parseInt(document.getElementById('budget-amount').value);if(!amount){showToast('Isi nominal budget');return;}const ei=APP.budget.categories.findIndex(b=>b.cat===cat);if(ei>=0)APP.budget.categories[ei].amount=amount;else APP.budget.categories.push({cat,amount});save();closeModal('modal-budget');showToast('Budget diperbarui');renderFinance();}
function saveNetWorth(){APP.networth.aset=parseInt(document.getElementById('nw-aset-in').value)||0;APP.networth.hutang=parseInt(document.getElementById('nw-hutang-in').value)||0;save();closeModal('modal-networth');showToast('Net worth diperbarui');if(document.getElementById('screen-home').classList.contains('active'))renderHome();}
function saveKendaraan(){const name=document.getElementById('kend-name').value.trim();if(!name){showToast('Isi nama kendaraan');return;}const item={name,jenis:document.getElementById('kend-jenis').value,plat:document.getElementById('kend-plat').value,tahun:document.getElementById('kend-tahun').value,pajak:document.getElementById('kend-pajak').value||null,servis:document.getElementById('kend-servis').value||null};const ei=document.getElementById('modal-kendaraan').dataset.editIdx;if(ei!==undefined)APP.kendaraan[parseInt(ei)]=item;else APP.kendaraan.push(item);save();closeModal('modal-kendaraan');showToast('Kendaraan tersimpan');renderKendaraan();}
function deleteKendaraan(){const ei=document.getElementById('modal-kendaraan').dataset.editIdx;if(ei===undefined)return;if(!confirm('Hapus kendaraan ini?'))return;APP.kendaraan.splice(parseInt(ei),1);save();closeModal('modal-kendaraan');showToast('Kendaraan dihapus');renderKendaraan();}
function saveServis(){const ki=parseInt(document.getElementById('servis-kend-select').value);const amount=parseInt(document.getElementById('servis-amount').value)||0;const item={kendIdx:ki,tipe:document.getElementById('servis-tipe').value,amount,date:document.getElementById('servis-date').value||today(),note:document.getElementById('servis-note').value};APP.servis.push(item);if(APP.kendaraan[ki])APP.kendaraan[ki].servis=item.date;if(amount>0){APP.transactions.push({desc:item.tipe+' — '+(APP.kendaraan[ki]?.name||'Kendaraan'),amount,type:'out',cat:'Kendaraan',who:'Bersama',date:item.date});}save();closeModal('modal-servis');showToast('Servis tersimpan');renderKendaraan();}
function saveInv(){const name=document.getElementById('inv-name').value.trim();if(!name){showToast('Isi nama barang');return;}const item={name,cat:document.getElementById('inv-cat').value,cond:document.getElementById('inv-cond').value,price:parseInt(document.getElementById('inv-price').value)||0,date:document.getElementById('inv-date').value||null,warranty:document.getElementById('inv-warranty').value||null};const ei=document.getElementById('modal-inv').dataset.editIdx;if(ei!==undefined)APP.inventaris[parseInt(ei)]=item;else APP.inventaris.push(item);save();closeModal('modal-inv');showToast('Barang tersimpan');renderInv(invFilter);}
function deleteInv(){const ei=document.getElementById('modal-inv').dataset.editIdx;if(ei===undefined)return;if(!confirm('Hapus barang ini?'))return;APP.inventaris.splice(parseInt(ei),1);save();closeModal('modal-inv');showToast('Barang dihapus');renderInv(invFilter);}
function saveKes(){const name=document.getElementById('kes-name').value.trim();if(!name){showToast('Isi nama');return;}const biaya=parseInt(document.getElementById('kes-biaya').value)||0;const item={tipe:document.getElementById('kes-tipe').value,who:document.getElementById('kes-who').value,name,biaya,date:document.getElementById('kes-date').value||today(),note:document.getElementById('kes-note').value};const ei=document.getElementById('modal-kes').dataset.editIdx;if(ei!==undefined)APP.kesehatan[parseInt(ei)]=item;else APP.kesehatan.push(item);if(biaya>0)APP.transactions.push({desc:name,amount:biaya,type:'out',cat:'Kesehatan',who:item.who,date:item.date});save();closeModal('modal-kes');showToast('Catatan tersimpan');renderKesehatan(kesTab);}
function deleteKes(){const ei=document.getElementById('modal-kes').dataset.editIdx;if(ei===undefined)return;if(!confirm('Hapus catatan ini?'))return;APP.kesehatan.splice(parseInt(ei),1);save();closeModal('modal-kes');showToast('Dihapus');renderKesehatan(kesTab);}
function saveDoc(){const name=document.getElementById('doc-name').value.trim();if(!name){showToast('Isi nama dokumen');return;}const ei=document.getElementById('modal-doc').dataset.editIdx;const prevStatus=ei!==undefined?APP.dokumen[parseInt(ei)].status:'unknown';const item={name,cat:document.getElementById('doc-cat').value,who:document.getElementById('doc-who').value,exp:document.getElementById('doc-exp').value||null,note:document.getElementById('doc-note').value,status:prevStatus,isDefault:ei!==undefined?(APP.dokumen[parseInt(ei)].isDefault||false):false};if(ei!==undefined)APP.dokumen[parseInt(ei)]=item;else APP.dokumen.push(item);save();closeModal('modal-doc');showToast('Dokumen tersimpan');renderDoc(docFilter);}
function deleteDoc(){const ei=document.getElementById('modal-doc').dataset.editIdx;if(ei===undefined)return;if(!confirm('Hapus dokumen ini?'))return;APP.dokumen.splice(parseInt(ei),1);save();closeModal('modal-doc');showToast('Dokumen dihapus');renderDoc(docFilter);}
function saveTodo(){const name=document.getElementById('todo-name').value.trim();if(!name){showToast('Isi nama tugas');return;}const item={name,prio:document.getElementById('todo-prio').value,who:document.getElementById('todo-who').value,due:document.getElementById('todo-due').value||null,status:'todo'};const ei=document.getElementById('modal-todo').dataset.editIdx;if(ei!==undefined){item.status=APP.todos[parseInt(ei)].status;APP.todos[parseInt(ei)]=item;}else APP.todos.push(item);save();closeModal('modal-todo');showToast('To-do tersimpan');renderJadwal();}
