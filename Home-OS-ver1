function selectMonth(idx,el){document.querySelectorAll('.month-tab').forEach(t=>t.classList.remove('active'));el.classList.add('active');curMonth=idx;renderFinanceMonth(idx);}
function renderFinanceMonth(mi){
  const months=['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
  const yr=new Date().getFullYear();
  const mTrx=APP.transactions.filter(t=>{const d=new Date(t.date);return d.getMonth()===mi&&d.getFullYear()===yr&&t.type==='out';});
  const total=mTrx.reduce((s,t)=>s+t.amount,0);
  document.getElementById('fin-total').textContent=fRp(total);
  document.getElementById('fin-month-lbl').textContent='Pengeluaran '+months[mi];
  // budget
  const bl=document.getElementById('budget-list');
  if(APP.budget.categories.length===0){bl.innerHTML='<div style="font-size:13px;color:var(--text-light);">Belum ada budget. Tap + Atur.</div>';}
  else{bl.innerHTML=APP.budget.categories.map((b,i)=>{
    const spent=mTrx.filter(t=>t.cat===b.cat).reduce((s,t)=>s+t.amount,0);
    const pct=Math.min(100,Math.round(spent/b.amount*100));
    const cls=pct>=100?'bud-over':pct>=80?'bud-warn':'bud-ok';
    return`<div class="budget-item"><div class="bud-row"><span class="bud-name">${b.cat}</span><span class="bud-val">${fRp(spent)} / ${fRp(b.amount)}</span></div><div class="bud-bar"><div class="bud-fill ${cls}" style="width:${pct}%"></div></div></div>`;
  }).join('');}
  // cicilan
  const cl=document.getElementById('cicilan-list');
  if(APP.cicilan.length===0){cl.innerHTML='<div style="font-size:13px;color:var(--text-light);padding:4px 0;">Belum ada cicilan.</div>';}
  else{cl.innerHTML=APP.cicilan.map((c,i)=>{
    const pct=Math.round(c.current/c.total*100);
    return`<div class="cicilan-card" onclick="editCicilan(${i})"><div class="cic-row"><div><div class="cic-name">${c.name}</div><div class="cic-sub">Cicilan ke-${c.current} dari ${c.total} · Est. lunas ${c.lunas}</div></div><div class="cic-amount">${fRp(c.amount)}</div></div><div class="cic-progress"><div class="cic-bar"><div class="cic-fill" style="width:${pct}%"></div></div><div class="cic-pct">${pct}%</div></div></div>`;
  }).join('');}
  // trx
  const tl=document.getElementById('trx-list');
  const all=APP.transactions.filter(t=>{const d=new Date(t.date);return d.getMonth()===mi&&d.getFullYear()===yr;}).slice().reverse();
  if(all.length===0){tl.innerHTML='<div style="font-size:13px;color:var(--text-light);padding:8px 0;">Belum ada transaksi bulan ini.</div>';}
  else{tl.innerHTML=all.map(t=>trxHTML(t)).join('');}
}
function trxHTML(t){
  return`<div class="trx-item"><div class="trx-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#7C6FE0" stroke-width="2" width="16" height="16"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg></div><div class="trx-info"><h4>${t.desc}</h4><p>${t.who||''} · ${fDateShort(t.date)} · ${t.cat}</p></div><div class="trx-amt ${t.type==='out'?'trx-out':'trx-in'}">${t.type==='out'?'-':'+'}${fRp(t.amount)}</div></div>`;
}


