<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="HomeOS">
<title>HomeOS</title>
<script>
  // Show loading screen immediately, hide splash
  document.addEventListener('DOMContentLoaded', function(){
    var ls = document.getElementById('loading-screen');
    if(ls) ls.style.display = 'flex';
    // Make sure splash is hidden while we check data
      });
</script>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root {
  --primary: #7C6FE0;
  --primary-light: #EEE9FF;
  --primary-mid: #B8AEFF;
  --accent-green: #4CAF8C;
  --accent-orange: #F5A623;
  --accent-red: #E05C5C;
  --accent-blue: #5CAEE0;
  --bg: #F5F5FA;
  --card: #FFFFFF;
  --text-dark: #1A1A2E;
  --text-mid: #6B6B8A;
  --text-light: #B0B0C8;
  --border: #EBEBF5;
  --shadow: 0 2px 16px rgba(124,111,224,0.08);
  --shadow-card: 0 1px 8px rgba(0,0,0,0.06);
  --bottom-h: 72px;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{font-family:'Poppins',sans-serif;background:var(--bg);color:var(--text-dark);max-width:430px;margin:0 auto;min-height:100vh;overflow-x:hidden;}

/* SCREENS */
.screen{display:none;min-height:100vh;padding-bottom:calc(var(--bottom-h) + 20px);animation:fadeUp .22s ease;}
.screen.active{display:block;}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* BOTTOM NAV */
.bottom-nav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:430px;height:var(--bottom-h);background:#fff;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-around;padding:0 8px 8px;z-index:100;box-shadow:0 -4px 20px rgba(0,0,0,0.06);}
.nav-item{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;flex:1;padding:8px 0;cursor:pointer;border:none;background:none;color:var(--text-light);transition:color .15s;}
.nav-item.active{color:var(--primary);}
.nav-item svg{width:22px;height:22px;}
.nav-item span{font-size:10px;font-weight:500;font-family:'Poppins',sans-serif;}
.nav-fab{width:52px;height:52px;background:var(--primary);border-radius:16px;display:flex;align-items:center;justify-content:center;cursor:pointer;border:none;box-shadow:0 4px 16px rgba(124,111,224,.4);transition:transform .2s;flex-shrink:0;}
.nav-fab:active{transform:scale(.93);}

/* FAB OVERLAY */
.fab-overlay{display:none;position:fixed;inset:0;z-index:200;background:rgba(26,26,46,.55);backdrop-filter:blur(4px);animation:fadeUp .2s ease;}
.fab-overlay.active{display:block;}
.fab-menu{position:absolute;bottom:calc(var(--bottom-h) + 12px);left:50%;transform:translateX(-50%);display:flex;flex-direction:column;gap:8px;align-items:center;width:230px;}
.fab-item{background:#fff;border-radius:14px;padding:14px 18px;width:100%;display:flex;align-items:center;gap:12px;cursor:pointer;box-shadow:0 4px 24px rgba(0,0,0,.13);animation:slideUp .2s ease backwards;border:none;font-family:'Poppins',sans-serif;font-size:14px;font-weight:600;color:var(--text-dark);transition:transform .15s;}
.fab-item:active{transform:scale(.97);}
.fab-item svg{width:20px;height:20px;color:var(--primary);flex-shrink:0;}
@keyframes slideUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.fab-item:nth-child(1){animation-delay:.04s}
.fab-item:nth-child(2){animation-delay:.07s}
.fab-item:nth-child(3){animation-delay:.10s}
.fab-item:nth-child(4){animation-delay:.13s}
.fab-item:nth-child(5){animation-delay:.16s}
.fab-item:nth-child(6){animation-delay:.19s}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;z-index:300;background:rgba(26,26,46,.55);backdrop-filter:blur(4px);align-items:flex-end;justify-content:center;}
.modal-overlay.active{display:flex;}
.modal-sheet{background:#fff;border-radius:24px 24px 0 0;width:100%;max-width:430px;padding:20px 24px 40px;max-height:92vh;overflow-y:auto;animation:sheetUp .25s ease;}
@keyframes sheetUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.modal-handle{width:36px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 20px;}
.modal-title{font-size:18px;font-weight:700;margin-bottom:20px;}

/* PAGE HEADER */
.page-header{padding:52px 24px 16px;background:#fff;}
.page-header-row{display:flex;align-items:center;justify-content:space-between;}
.greeting-sub{font-size:12px;color:var(--primary);font-weight:600;margin-bottom:2px;}
.greeting-name{font-size:22px;font-weight:800;color:var(--text-dark);}
.avatar{width:40px;height:40px;background:var(--primary-light);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:var(--primary);}
.icon-btn{background:var(--primary-light);border:none;border-radius:12px;padding:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:opacity .15s;}
.icon-btn:active{opacity:.7;}

/* NET WORTH CARD */
.nw-card{background:var(--primary);border-radius:20px;padding:20px 22px;margin:0 20px 18px;color:#fff;position:relative;overflow:hidden;}
.nw-card::before{content:'';position:absolute;top:-28px;right:-28px;width:110px;height:110px;background:rgba(255,255,255,.09);border-radius:50%;}
.nw-card::after{content:'';position:absolute;bottom:-18px;right:36px;width:70px;height:70px;background:rgba(255,255,255,.05);border-radius:50%;}
.nw-label{font-size:11px;opacity:.8;margin-bottom:3px;}
.nw-amount{font-size:28px;font-weight:900;margin-bottom:16px;}
.nw-row{display:flex;gap:20px;}
.nw-item label{font-size:10px;opacity:.7;display:block;}
.nw-item span{font-size:13px;font-weight:700;}
.nw-item.g span{color:#7DFFC3;}
.nw-item.r span{color:#FFB3B3;}

/* STATS ROW */
.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;padding:0 20px;margin-bottom:22px;}
.stat-card{background:var(--card);border-radius:16px;padding:14px 10px;box-shadow:var(--shadow-card);display:flex;flex-direction:column;align-items:center;text-align:center;cursor:pointer;transition:transform .15s;}
.stat-card:active{transform:scale(.97);}
.stat-card svg{width:18px;height:18px;margin-bottom:5px;}
.stat-num{font-size:20px;font-weight:800;color:var(--text-dark);}
.stat-label{font-size:10px;color:var(--text-mid);}

/* SECTION */
.section{padding:0 20px;margin-bottom:22px;}
.section-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;}
.section-title{font-size:15px;font-weight:700;}
.section-link{font-size:12px;color:var(--primary);font-weight:500;cursor:pointer;background:none;border:none;font-family:'Poppins',sans-serif;}

/* REMINDER SCROLL */
.rem-scroll{display:flex;gap:10px;overflow-x:auto;scrollbar-width:none;padding-bottom:2px;}
.rem-scroll::-webkit-scrollbar{display:none;}
.rem-card{background:var(--card);border-radius:16px;padding:14px 16px;min-width:175px;box-shadow:var(--shadow-card);flex-shrink:0;cursor:pointer;}
.rem-cat{font-size:10px;font-weight:700;margin-bottom:5px;display:flex;align-items:center;gap:4px;}
.rem-cat.fin{color:var(--primary);}
.rem-cat.veh{color:var(--accent-orange);}
.rem-cat.doc{color:var(--accent-blue);}
.rem-cat.health{color:var(--accent-green);}
.rem-card h4{font-size:13px;font-weight:700;margin-bottom:2px;}
.rem-card p{font-size:11px;color:var(--text-mid);}
.rem-card .rem-amount{font-size:12px;font-weight:700;color:var(--text-dark);margin-top:4px;}

/* CHORE ITEM */
.chore-item{background:var(--card);border-radius:14px;padding:14px 16px;margin-bottom:8px;display:flex;align-items:center;gap:12px;box-shadow:var(--shadow-card);}
.chore-check{width:22px;height:22px;border:2px solid var(--border);border-radius:7px;flex-shrink:0;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;}
.chore-check.done{background:var(--primary);border-color:var(--primary);}
.chore-check.overdue{border-color:var(--accent-red);}
.chore-info{flex:1;min-width:0;}
.chore-info h4{font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.chore-info p{font-size:11px;color:var(--text-mid);margin-top:1px;}
.chore-status{font-size:11px;font-weight:600;flex-shrink:0;}
.cs-done{color:var(--accent-green);}
.cs-overdue{color:var(--accent-red);}
.cs-today{color:var(--accent-orange);}
.cs-pending{color:var(--text-mid);}

/* FINANCE */
.fin-header{background:#fff;padding:52px 24px 0;}
.fin-total-label{font-size:12px;color:var(--text-mid);margin-bottom:2px;}
.fin-total{font-size:30px;font-weight:900;color:var(--text-dark);}
.fin-sub{font-size:12px;color:var(--text-mid);margin-bottom:16px;}
.month-tabs{display:flex;overflow-x:auto;scrollbar-width:none;border-bottom:1px solid var(--border);}
.month-tabs::-webkit-scrollbar{display:none;}
.month-tab{padding:10px 14px;font-size:12px;font-weight:500;color:var(--text-mid);cursor:pointer;border:none;border-bottom:2px solid transparent;background:none;font-family:'Poppins',sans-serif;white-space:nowrap;transition:all .2s;margin-bottom:-1px;}
.month-tab.active{color:var(--primary);border-bottom-color:var(--primary);font-weight:700;}
.fin-content{padding:16px 20px;}

/* BUDGET CARD */
.card{background:var(--card);border-radius:16px;padding:16px 18px;box-shadow:var(--shadow-card);margin-bottom:14px;}
.card-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;}
.card-title{font-size:14px;font-weight:700;}
.card-action{font-size:12px;color:var(--primary);font-weight:500;cursor:pointer;background:none;border:none;font-family:'Poppins',sans-serif;}
.budget-item{margin-bottom:13px;}
.budget-item:last-child{margin-bottom:0;}
.bud-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;}
.bud-name{font-size:13px;}
.bud-val{font-size:11px;color:var(--text-mid);}
.bud-bar{height:6px;background:var(--border);border-radius:3px;overflow:hidden;}
.bud-fill{height:100%;border-radius:3px;transition:width .5s ease;}
.bud-ok{background:var(--primary);}
.bud-warn{background:var(--accent-orange);}
.bud-over{background:var(--accent-red);}

/* CICILAN */
.cicilan-card{background:var(--card);border-radius:14px;padding:15px 16px;box-shadow:var(--shadow-card);margin-bottom:10px;}
.cic-row{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;}
.cic-name{font-size:14px;font-weight:700;}
.cic-amount{font-size:14px;font-weight:700;color:var(--primary);}
.cic-sub{font-size:11px;color:var(--text-mid);}
.cic-progress{display:flex;align-items:center;gap:8px;margin-top:8px;}
.cic-bar{flex:1;height:5px;background:var(--border);border-radius:3px;overflow:hidden;}
.cic-fill{height:100%;background:var(--primary);border-radius:3px;}
.cic-pct{font-size:10px;color:var(--text-mid);font-weight:600;flex-shrink:0;}

/* TRX */
.trx-item{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid var(--border);}
.trx-item:last-child{border-bottom:none;}
.trx-icon{width:36px;height:36px;border-radius:11px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.trx-icon svg{width:16px;height:16px;color:var(--primary);}
.trx-info{flex:1;min-width:0;}
.trx-info h4{font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.trx-info p{font-size:10px;color:var(--text-mid);}
.trx-amt{font-size:13px;font-weight:700;flex-shrink:0;}
.trx-out{color:var(--accent-red);}
.trx-in{color:var(--accent-green);}

/* GROCERIES */
.groc-section{font-size:10px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--text-mid);margin:14px 0 8px;}
.groc-item{background:var(--card);border-radius:13px;padding:13px 14px;margin-bottom:7px;display:flex;align-items:center;gap:10px;box-shadow:var(--shadow-card);cursor:pointer;transition:transform .12s;}
.groc-item:active{transform:scale(.98);}
.groc-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}
.d-habis{background:var(--accent-red);}
.d-hampir{background:var(--accent-orange);}
.d-cukup{background:var(--accent-green);}
.groc-info{flex:1;min-width:0;}
.groc-info h4{font-size:13px;font-weight:500;}
.groc-info p{font-size:10px;color:var(--text-mid);}
.groc-status{font-size:11px;font-weight:700;flex-shrink:0;}
.s-habis{color:var(--accent-red);}
.s-hampir{color:var(--accent-orange);}
.s-cukup{color:var(--accent-green);}
.s-skip{color:var(--text-light);}
.gen-btn{position:sticky;bottom:calc(var(--bottom-h) + 8px);width:100%;padding:15px;background:var(--primary);color:#fff;border:none;border-radius:16px;font-family:'Poppins',sans-serif;font-size:14px;font-weight:700;cursor:pointer;box-shadow:0 4px 16px rgba(124,111,224,.35);margin-top:12px;transition:opacity .15s;}
.gen-btn:active{opacity:.85;}

/* CHORES SCREEN */
.chore-detail{font-size:10px;color:var(--text-light);margin-top:2px;}

/* MENU */
.menu-content{padding:12px 20px;}
.menu-section-lbl{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-mid);margin:18px 0 10px;}
.menu-section-lbl:first-child{margin-top:4px;}
.menu-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.menu-card{background:var(--card);border-radius:16px;padding:16px;box-shadow:var(--shadow-card);cursor:pointer;transition:transform .15s;border:none;text-align:left;width:100%;}
.menu-card:active{transform:scale(.97);}
.menu-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:10px;}
.menu-icon svg{width:19px;height:19px;}
.menu-card h4{font-size:13px;font-weight:700;color:var(--text-dark);margin-bottom:2px;}
.menu-card p{font-size:11px;color:var(--text-mid);line-height:1.4;}
.mbadge{display:inline-block;margin-top:6px;font-size:10px;font-weight:700;padding:3px 9px;border-radius:20px;}
.mb-red{background:#FFE5E5;color:var(--accent-red);}
.mb-orange{background:#FFF3DC;color:var(--accent-orange);}
.mb-green{background:#E5F7EF;color:var(--accent-green);}
.mb-purple{background:var(--primary-light);color:var(--primary);}

/* PROFIL */
.profil-card{background:var(--card);border-radius:20px;padding:24px;box-shadow:var(--shadow-card);margin-bottom:14px;text-align:center;}
.profil-av{width:68px;height:68px;background:var(--primary-light);border-radius:20px;display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:900;color:var(--primary);margin:0 auto 12px;}
.profil-name{font-size:18px;font-weight:800;}
.profil-sub{font-size:12px;color:var(--text-mid);}
.setting-item{background:var(--card);border-radius:14px;padding:14px 16px;margin-bottom:8px;display:flex;align-items:center;gap:12px;box-shadow:var(--shadow-card);cursor:pointer;}
.setting-item:active{opacity:.8;}
.sett-icon{width:36px;height:36px;background:var(--primary-light);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.sett-icon svg{width:18px;height:18px;color:var(--primary);}
.sett-info{flex:1;}
.sett-info h4{font-size:13px;font-weight:600;}
.sett-info p{font-size:11px;color:var(--text-mid);}
.sett-arrow{color:var(--text-light);}

/* KENDARAAN */
.kend-card{background:var(--card);border-radius:16px;padding:16px;box-shadow:var(--shadow-card);margin-bottom:10px;cursor:pointer;}
.kend-card:active{opacity:.85;}
.kend-row{display:flex;align-items:center;gap:12px;margin-bottom:8px;}
.kend-icon{width:44px;height:44px;border-radius:13px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;}
.kend-icon svg{width:22px;height:22px;color:var(--primary);}
.kend-name{font-size:15px;font-weight:700;}
.kend-sub{font-size:11px;color:var(--text-mid);}
.kend-tags{display:flex;gap:6px;flex-wrap:wrap;}
.kend-tag{font-size:10px;font-weight:600;padding:3px 9px;border-radius:20px;}

/* TABS */
.tab-filter{display:flex;gap:6px;overflow-x:auto;scrollbar-width:none;padding:0;}
.tab-filter::-webkit-scrollbar{display:none;}
.tab-btn{padding:7px 14px;border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;border:none;font-family:'Poppins',sans-serif;transition:all .2s;background:var(--border);color:var(--text-mid);white-space:nowrap;}
.tab-btn.active{background:var(--primary);color:#fff;}

/* FORM */
.form-group{margin-bottom:15px;}
.form-label{font-size:11px;font-weight:700;color:var(--text-mid);display:block;margin-bottom:7px;letter-spacing:.3px;}
.form-input{width:100%;padding:12px 14px;border:1.5px solid var(--border);border-radius:12px;font-family:'Poppins',sans-serif;font-size:14px;color:var(--text-dark);background:var(--bg);outline:none;transition:border-color .2s;}
.form-input:focus{border-color:var(--primary);}
.form-select{width:100%;padding:12px 14px;border:1.5px solid var(--border);border-radius:12px;font-family:'Poppins',sans-serif;font-size:14px;color:var(--text-dark);background:var(--bg);outline:none;appearance:none;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.modal-actions{display:flex;gap:10px;margin-top:18px;}
.btn-cancel{flex:1;padding:13px;border:1.5px solid var(--border);border-radius:14px;background:none;font-family:'Poppins',sans-serif;font-size:14px;font-weight:600;color:var(--text-mid);cursor:pointer;}
.btn-save{flex:2;padding:13px;background:var(--primary);border:none;border-radius:14px;color:#fff;font-family:'Poppins',sans-serif;font-size:14px;font-weight:700;cursor:pointer;transition:opacity .15s;}
.btn-save:active{opacity:.85;}
.btn-danger{flex:1;padding:13px;background:#FFE5E5;border:none;border-radius:14px;color:var(--accent-red);font-family:'Poppins',sans-serif;font-size:14px;font-weight:700;cursor:pointer;}

/* TOAST */
.toast{position:fixed;top:60px;left:50%;transform:translateX(-50%);background:var(--text-dark);color:#fff;padding:11px 20px;border-radius:12px;font-size:13px;font-weight:500;z-index:999;opacity:0;transition:opacity .3s;white-space:nowrap;box-shadow:0 4px 20px rgba(0,0,0,.2);pointer-events:none;}
.toast.show{opacity:1;}

/* EMPTY STATE */
.empty-state{text-align:center;padding:40px 20px;color:var(--text-mid);}
.empty-state svg{width:44px;height:44px;margin-bottom:10px;opacity:.3;}
.empty-state p{font-size:13px;}

/* GOALS */
.goal-card{background:var(--card);border-radius:14px;padding:15px 16px;margin-bottom:10px;box-shadow:var(--shadow-card);}
.goal-row{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;}
.goal-name{font-size:14px;font-weight:700;}
.goal-cat{font-size:10px;font-weight:600;padding:2px 8px;border-radius:20px;background:var(--primary-light);color:var(--primary);}
.goal-progress{display:flex;align-items:center;gap:8px;}
.goal-bar{flex:1;height:6px;background:var(--border);border-radius:3px;overflow:hidden;}
.goal-fill{height:100%;background:var(--primary);border-radius:3px;}
.goal-pct{font-size:11px;color:var(--text-mid);font-weight:600;flex-shrink:0;}
.goal-amounts{display:flex;justify-content:space-between;margin-top:6px;}
.goal-amounts span{font-size:11px;color:var(--text-mid);}
.goal-amounts strong{font-size:11px;color:var(--text-dark);font-weight:700;}

/* PERJALANAN */
.trip-card{background:var(--card);border-radius:16px;overflow:hidden;box-shadow:var(--shadow-card);margin-bottom:12px;cursor:pointer;}
.trip-header{background:var(--primary);padding:14px 16px;color:#fff;}
.trip-dest{font-size:16px;font-weight:800;}
.trip-date{font-size:11px;opacity:.8;margin-top:2px;}
.trip-body{padding:14px 16px;}
.trip-row{display:flex;justify-content:space-between;margin-bottom:6px;}
.trip-row:last-child{margin-bottom:0;}
.trip-row span{font-size:12px;color:var(--text-mid);}
.trip-row strong{font-size:12px;font-weight:700;}

/* INVENTARIS */
.inv-item{background:var(--card);border-radius:13px;padding:13px 15px;margin-bottom:8px;display:flex;align-items:center;gap:12px;box-shadow:var(--shadow-card);cursor:pointer;}
.inv-icon{width:36px;height:36px;border-radius:10px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.inv-icon svg{width:16px;height:16px;color:var(--primary);}
.inv-info{flex:1;min-width:0;}
.inv-info h4{font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.inv-info p{font-size:10px;color:var(--text-mid);}
.inv-condition{font-size:10px;font-weight:700;padding:2px 8px;border-radius:20px;flex-shrink:0;}
.cond-baik{background:#E5F7EF;color:var(--accent-green);}
.cond-perlu{background:#FFF3DC;color:var(--accent-orange);}
.cond-rusak{background:#FFE5E5;color:var(--accent-red);}

/* KESEHATAN */
.health-profile{background:var(--card);border-radius:16px;padding:16px;box-shadow:var(--shadow-card);margin-bottom:14px;}
.health-tabs{display:flex;gap:6px;margin-bottom:16px;}
.health-stat-row{display:flex;gap:10px;margin-bottom:10px;}
.health-stat{background:var(--bg);border-radius:10px;padding:10px 12px;flex:1;}
.health-stat label{font-size:10px;color:var(--text-mid);display:block;margin-bottom:2px;}
.health-stat span{font-size:15px;font-weight:800;color:var(--text-dark);}

/* DOKUMEN */
.doc-item{background:var(--card);border-radius:13px;padding:13px 15px;margin-bottom:8px;display:flex;align-items:center;gap:12px;box-shadow:var(--shadow-card);}
.doc-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.doc-info{flex:1;min-width:0;}
.doc-info h4{font-size:13px;font-weight:600;}
.doc-info p{font-size:10px;color:var(--text-mid);}
.doc-exp{font-size:10px;font-weight:700;flex-shrink:0;}
.doc-ok{color:var(--accent-green);}
.doc-warn{color:var(--accent-orange);}
.doc-late{color:var(--accent-red);}

/* SOSIAL */
.contact-item{background:var(--card);border-radius:13px;padding:13px 15px;margin-bottom:8px;display:flex;align-items:center;gap:12px;box-shadow:var(--shadow-card);cursor:pointer;}
.contact-av{width:38px;height:38px;border-radius:12px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;color:var(--primary);flex-shrink:0;}
.contact-info{flex:1;}
.contact-info h4{font-size:13px;font-weight:600;}
.contact-info p{font-size:10px;color:var(--text-mid);}
.contact-badge{font-size:10px;font-weight:700;padding:2px 8px;border-radius:20px;background:#FFE5E5;color:var(--accent-red);}

/* ENERGI */
.energi-card{background:var(--card);border-radius:14px;padding:15px 16px;margin-bottom:10px;box-shadow:var(--shadow-card);}
.energi-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;}
.energi-name{font-size:14px;font-weight:700;}
.energi-amount{font-size:15px;font-weight:800;color:var(--primary);}
.energi-trend{font-size:11px;font-weight:600;}
.trend-up{color:var(--accent-red);}
.trend-down{color:var(--accent-green);}
.trend-same{color:var(--text-mid);}

/* PENDIDIKAN */
.edu-card{background:var(--card);border-radius:14px;padding:15px 16px;margin-bottom:10px;box-shadow:var(--shadow-card);cursor:pointer;}
.edu-row{display:flex;justify-content:space-between;align-items:flex-start;}
.edu-name{font-size:14px;font-weight:700;margin-bottom:2px;}
.edu-platform{font-size:11px;color:var(--text-mid);}
.edu-status{font-size:10px;font-weight:700;padding:2px 9px;border-radius:20px;}
.edu-ongoing{background:var(--primary-light);color:var(--primary);}
.edu-done{background:#E5F7EF;color:var(--accent-green);}
.edu-paused{background:#FFF3DC;color:var(--accent-orange);}

/* TIMELINE */
.timeline-item{background:var(--card);border-radius:14px;padding:13px 15px;margin-bottom:8px;display:flex;gap:12px;box-shadow:var(--shadow-card);}
.tl-dot-wrap{display:flex;flex-direction:column;align-items:center;flex-shrink:0;width:10px;}
.tl-dot{width:10px;height:10px;border-radius:50%;margin-top:3px;}
.tl-line{flex:1;width:2px;background:var(--border);margin-top:4px;}
.tl-info h4{font-size:13px;font-weight:600;margin-bottom:2px;}
.tl-info p{font-size:11px;color:var(--text-mid);}
.tl-right{text-align:right;flex-shrink:0;}
.tl-date{font-size:10px;color:var(--text-light);}
.tl-amount{font-size:12px;font-weight:700;margin-top:2px;}

/* PROPERTI */
.prop-card{background:var(--card);border-radius:16px;padding:16px;box-shadow:var(--shadow-card);margin-bottom:12px;}
.prop-badge{display:inline-block;font-size:10px;font-weight:700;padding:3px 10px;border-radius:20px;margin-bottom:8px;}
.prop-name{font-size:16px;font-weight:800;margin-bottom:4px;}
.prop-info-row{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:8px;}
.prop-info-item label{font-size:10px;color:var(--text-mid);display:block;}
.prop-info-item span{font-size:13px;font-weight:600;}
.renovasi-card{background:var(--bg);border-radius:12px;padding:12px 14px;margin-bottom:8px;}
.ren-row{display:flex;justify-content:space-between;align-items:center;}
.ren-name{font-size:13px;font-weight:700;}
.ren-status{font-size:10px;font-weight:700;padding:2px 8px;border-radius:20px;}
.ren-planning{background:#FFF3DC;color:var(--accent-orange);}
.ren-progress{background:var(--primary-light);color:var(--primary);}
.ren-done{background:#E5F7EF;color:var(--accent-green);}

/* DELETE BTN */
.delete-btn{background:none;border:none;cursor:pointer;padding:4px;margin-left:8px;}
.delete-btn svg{width:16px;height:16px;color:var(--accent-red);}

/* SEARCH BAR */
.search-bar{display:flex;align-items:center;background:var(--bg);border-radius:12px;padding:10px 14px;gap:8px;margin:12px 0 0;}
.search-bar input{border:none;background:none;outline:none;font-family:'Poppins',sans-serif;font-size:14px;color:var(--text-dark);flex:1;}
.search-bar input::placeholder{color:var(--text-light);}

/* LIST BELANJA */
.lb-text{background:var(--bg);border-radius:12px;padding:14px;font-size:13px;line-height:1.9;color:var(--text-dark);white-space:pre-wrap;margin-bottom:14px;font-family:'Poppins',sans-serif;}
.copy-btn{width:100%;padding:14px;background:var(--primary);border:none;border-radius:14px;color:#fff;font-family:'Poppins',sans-serif;font-size:14px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;}

/* HUTANG PIUTANG */
.hutang-item{background:var(--card);border-radius:13px;padding:13px 15px;margin-bottom:8px;display:flex;align-items:center;gap:10px;box-shadow:var(--shadow-card);}
.hutang-info{flex:1;}
.hutang-info h4{font-size:13px;font-weight:600;}
.hutang-info p{font-size:10px;color:var(--text-mid);}
.hutang-amount{font-size:13px;font-weight:800;}
.hutang-piutang{color:var(--accent-green);}
.hutang-hutang{color:var(--accent-red);}
/* LOADING SCREEN */
#loading-screen{position:fixed;inset:0;background:#fff;z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;}
.loading-logo{width:64px;height:64px;background:var(--primary-light);border-radius:20px;display:flex;align-items:center;justify-content:center;}
.loading-spinner{width:28px;height:28px;border:3px solid var(--border);border-top-color:var(--primary);border-radius:50%;animation:spin .8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-text{font-size:13px;color:var(--text-mid);font-weight:500;}
/* SYNC INDICATOR */
#sync-indicator{position:fixed;top:12px;right:16px;font-size:11px;font-weight:600;z-index:500;transition:opacity .4s;opacity:0;pointer-events:none;}


/* GROCERY ADA/BELI/SKIP buttons */
.groc-adas{display:flex;gap:4px;align-items:center;flex-shrink:0;}
.gas-btn{padding:4px 9px;border-radius:20px;font-size:11px;font-weight:700;cursor:pointer;border:1.5px solid var(--border);background:var(--bg);color:var(--text-mid);font-family:'Poppins',sans-serif;transition:all .15s;white-space:nowrap;}
.gas-btn:active{transform:scale(.95);}
.gas-ada-active{background:#E5F7EF!important;border-color:#4CAF8C!important;color:#4CAF8C!important;}
.gas-beli-active{background:#FFE5E5!important;border-color:#E05C5C!important;color:#E05C5C!important;}
.gas-skip-active{background:var(--border)!important;border-color:var(--text-light)!important;color:var(--text-light)!important;}
.groc-master .groc-info h4{font-size:13px;font-weight:400;color:var(--text-mid);}
/* Grocery mode tabs */
.groc-mode-tabs{display:flex;background:var(--bg);border-radius:12px;padding:3px;margin:12px 0 0;}
.groc-mode-btn{flex:1;padding:8px;border:none;border-radius:9px;font-family:'Poppins',sans-serif;font-size:12px;font-weight:600;cursor:pointer;background:none;color:var(--text-mid);transition:all .2s;}
.groc-mode-btn.active{background:#fff;color:var(--primary);box-shadow:var(--shadow-card);}
/* Category scroll in groceries */
.cat-scroll{display:flex;gap:6px;overflow-x:auto;scrollbar-width:none;padding:10px 0 4px;}
.cat-scroll::-webkit-scrollbar{display:none;}
/* Doc toggle */
.doc-tog{padding:4px 10px;border-radius:20px;font-size:11px;font-weight:700;cursor:pointer;border:1.5px solid var(--border);background:var(--bg);color:var(--text-mid);font-family:'Poppins',sans-serif;transition:all .15s;}
.doc-tog-active-ada{background:#E5F7EF!important;border-color:#4CAF8C!important;color:#4CAF8C!important;}
.doc-tog-active-tidak{background:#FFE5E5!important;border-color:#E05C5C!important;color:#E05C5C!important;}
/* Groc stats */
.groc-stats{display:flex;align-items:center;margin:8px 0 4px;padding:8px 12px;background:var(--card);border-radius:10px;box-shadow:var(--shadow-card);}


.batch-row{background:var(--bg);border-radius:12px;padding:10px;margin-bottom:8px;position:relative;}
.batch-row-top{display:flex;gap:6px;align-items:center;margin-bottom:6px;}
.batch-row-bot{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:5px;}
.batch-input{width:100%;padding:8px 10px;border:1.5px solid var(--border);border-radius:9px;font-family:'Poppins',sans-serif;font-size:12px;color:var(--text-dark);background:#fff;outline:none;transition:border-color .2s;}
.batch-input:focus{border-color:var(--primary);}
.batch-label{font-size:10px;font-weight:700;color:var(--text-mid);display:block;margin-bottom:3px;}
.batch-del{background:none;border:none;cursor:pointer;padding:4px;flex-shrink:0;}
.batch-del svg{width:16px;height:16px;color:var(--accent-red);}
.stok-hist-item{background:var(--bg);border-radius:10px;padding:10px 12px;margin-bottom:6px;}
.stok-hist-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;}
.stok-hist-toko{font-size:13px;font-weight:700;color:var(--text-dark);}
.stok-hist-date{font-size:10px;color:var(--text-light);}
.stok-hist-row{display:flex;gap:14px;flex-wrap:wrap;}
.stok-hist-row span{font-size:11px;color:var(--text-mid);}
.stok-hist-row strong{font-size:11px;color:var(--text-dark);font-weight:700;}
.riwayat-session{background:var(--card);border-radius:14px;padding:14px 16px;margin-bottom:10px;box-shadow:var(--shadow-card);}
.riwayat-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;}
.riwayat-toko{font-size:15px;font-weight:800;color:var(--text-dark);}
.riwayat-date{font-size:11px;color:var(--text-mid);margin-top:2px;}
.riwayat-total{font-size:14px;font-weight:800;color:var(--primary);}
.riwayat-items{display:flex;flex-direction:column;gap:4px;}
.riwayat-item-row{display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-top:1px solid var(--border);}
.riwayat-item-name{font-size:12px;font-weight:600;}
.riwayat-item-detail{font-size:11px;color:var(--text-mid);}
/* INLINE QTY INPUT */
.groc-item-open{background:var(--card);border-radius:14px;box-shadow:0 2px 12px rgba(76,175,140,.13);}
.groc-qty-row{display:flex;align-items:center;gap:5px;margin-top:7px;animation:fadeUp .15s ease;}
.groc-qty-input{width:64px;padding:6px 8px;border:1.5px solid var(--accent-green);border-radius:9px;font-family:'Poppins',sans-serif;font-size:13px;font-weight:600;color:var(--text-dark);background:#fff;outline:none;-moz-appearance:textfield;}
.groc-qty-input::-webkit-inner-spin-button,.groc-qty-input::-webkit-outer-spin-button{-webkit-appearance:none;}
.groc-qty-sel{padding:6px 8px;border:1.5px solid var(--border);border-radius:9px;font-family:'Poppins',sans-serif;font-size:12px;font-weight:600;color:var(--text-dark);background:#fff;outline:none;max-width:72px;}
.groc-qty-ok{width:32px;height:32px;border-radius:9px;background:var(--accent-green);border:none;color:#fff;font-size:14px;font-weight:800;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:opacity .15s;}
.groc-qty-ok:active{opacity:.8;}
</style>
</head>
