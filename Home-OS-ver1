const SB_HEADERS = {
  'Content-Type': 'application/json',
  'apikey': SB_KEY,
  'Authorization': 'Bearer ' + SB_KEY
};

// ============================================================
// DATA LAYER — localStorage (cache) + Supabase (cloud sync)
// ============================================================
const SK = 'homeos_v2';
let isSyncing = false;
let saveQueue = null;
let saveTimer = null;

function defData(){return{profile:{name1:'Naufal',name2:'Audya'},networth:{aset:0,hutang:0},budget:{total:22000000,categories:[]},cicilan:[],transactions:[],groceries:[],chores:[],kendaraan:[],servis:[],inventaris:[],kesehatan:[],dokumen:[],todos:[],goals:[],sosial:[],trips:[],energi:[],pendidikan:[],properti:[],lastOpname:null,belanjaLog:[]};}

function load(){
  try{const r=localStorage.getItem(SK);return r?JSON.parse(r):null;}
  catch(e){return null;}
}

// Save: write to localStorage immediately, then debounce cloud sync
function save(){
  localStorage.setItem(SK, JSON.stringify(APP));
  // Debounce: wait 1.5s of inactivity before syncing to Supabase
  clearTimeout(saveTimer);
  saveTimer = setTimeout(()=>syncToSupabase(), 1500);
}

async function syncToSupabase(){
  if(isSyncing) { saveQueue = true; return; }
  isSyncing = true;
  showSyncIndicator(true);
  try {
    // Use UPSERT (POST with Prefer: resolution=merge-duplicates)
    // This works whether the row exists or not
    const upsertHeaders = {
      ...SB_HEADERS,
      'Prefer': 'resolution=merge-duplicates'
    };
    const res = await fetch(`${SB_URL}/rest/v1/homeos_data`, {
      method: 'POST',
      headers: upsertHeaders,
      body: JSON.stringify({ id: 'main', data: APP, updated_at: new Date().toISOString() })
    });
    if(!res.ok) {
      // Fallback: try PATCH
      const res2 = await fetch(`${SB_URL}/rest/v1/homeos_data?id=eq.main`, {
        method: 'PATCH',
        headers: SB_HEADERS,
        body: JSON.stringify({ data: APP, updated_at: new Date().toISOString() })
      });
      if(!res2.ok) throw new Error('Sync failed: ' + res2.status);
    }
    showSyncIndicator(false, true);
  } catch(e) {
    console.warn('Supabase sync error:', e);
    showSyncIndicator(false, false);
  } finally {
    isSyncing = false;
    if(saveQueue){ saveQueue = false; syncToSupabase(); }
  }
}

async function loadFromSupabase(){
  try {
    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), 5000); // 5s timeout
    const res = await fetch(`${SB_URL}/rest/v1/homeos_data?id=eq.main&select=data,updated_at`, {
      headers: SB_HEADERS,
      signal: controller.signal
    });
    clearTimeout(timeout);
    if(!res.ok) throw new Error('Load failed');
    const rows = await res.json();
    if(rows && rows.length > 0 && rows[0].data && Object.keys(rows[0].data).length > 0){
      return rows[0].data;
    }
  } catch(e) {
    console.warn('Supabase load error:', e.name === 'AbortError' ? 'Timeout (5s)' : e);
  }
  return null;
}

// Sync indicator UI
function showSyncIndicator(syncing, success){
  let el = document.getElementById('sync-indicator');
  if(!el) return;
  if(syncing){
    el.innerHTML = `<span style="color:var(--accent-orange);">⟳ Menyimpan...</span>`;
    el.style.opacity = '1';
  } else if(success === true){
    el.innerHTML = `<span style="color:var(--accent-green);">✓ Tersimpan</span>`;
    el.style.opacity = '1';
    setTimeout(()=>{ el.style.opacity = '0'; }, 2000);
  } else {
    el.innerHTML = `<span style="color:var(--accent-red);">✗ Gagal sync</span>`;
    el.style.opacity = '1';
    setTimeout(()=>{ el.style.opacity = '0'; }, 3000);
  }
}

// Enable Supabase realtime subscription for live sync between devices
function setupRealtimeSync(){
  // Poll every 30 seconds for changes from other device
  setInterval(async ()=>{
    if(isSyncing) return;
    try {
      const res = await fetch(`${SB_URL}/rest/v1/homeos_data?id=eq.main&select=data,updated_at`, {
        headers: SB_HEADERS
      });
      if(!res.ok) return;
      const rows = await res.json();
      if(!rows || rows.length === 0) return;
      const remoteTime = new Date(rows[0].updated_at).getTime();
      const localTime = APP._lastSaved || 0;
      // If remote is newer than what we last saved, pull it
      if(remoteTime > localTime + 5000){ // 5s buffer
        const remoteData = rows[0].data;
        if(remoteData && remoteData.profile){
          APP = remoteData;
          APP._lastSaved = remoteTime;
          localStorage.setItem(SK, JSON.stringify(APP));
          // Re-render current screen
          const activeScreen = document.querySelector('.screen.active');
          if(activeScreen){
            const page = activeScreen.id.replace('screen-','');
            const renders = {home:renderHome,finance:renderFinance,groceries:renderGroceries,chores:renderChores,menu:renderMenu};
            if(renders[page]) renders[page]();
          }
          showToast('🔄 Data diperbarui dari perangkat lain');
        }
      }
    } catch(e){ /* silent fail */ }
  }, 30000);
}

