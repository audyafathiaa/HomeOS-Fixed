// ============================================================
// FORMAT
// ============================================================
function fRp(n){n=parseInt(n)||0;const abs=Math.abs(n);let s='';if(abs>=1000000000)s='Rp '+(abs/1000000000).toFixed(1)+' M';else if(abs>=1000000)s='Rp '+(abs/1000000).toFixed(1)+' jt';else if(abs>=1000)s='Rp '+Math.round(abs/1000)+'rb';else s='Rp '+abs.toLocaleString('id-ID');return(n<0?'-':'')+s;}
function fDate(d){if(!d)return'—';return new Date(d).toLocaleDateString('id-ID',{day:'numeric',month:'short',year:'numeric'});}
function fDateShort(d){if(!d)return'—';return new Date(d).toLocaleDateString('id-ID',{day:'numeric',month:'short'});}
function today(){return new Date().toISOString().slice(0,10);}
function daysDiff(d){if(!d)return null;return Math.round((new Date(d)-new Date())/(1000*60*60*24));}

