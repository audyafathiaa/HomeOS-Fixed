function saveGoal(){const name=document.getElementById('goal-name').value.trim();if(!name){showToast('Isi nama goal');return;}const item={name,cat:document.getElementById('goal-cat').value,who:document.getElementById('goal-who').value,target:parseInt(document.getElementById('goal-target').value)||0,current:parseInt(document.getElementById('goal-current').value)||0,deadline:document.getElementById('goal-deadline').value||null};const ei=document.getElementById('modal-goal').dataset.editIdx;if(ei!==undefined)APP.goals[parseInt(ei)]=item;else APP.goals.push(item);save();closeModal('modal-goal');showToast('Goal tersimpan');renderGoals();}
function deleteGoal(){const ei=document.getElementById('modal-goal').dataset.editIdx;if(ei===undefined)return;if(!confirm('Hapus goal ini?'))return;APP.goals.splice(parseInt(ei),1);save();closeModal('modal-goal');showToast('Goal dihapus');renderGoals();}
function saveSosial(){const name=document.getElementById('sosial-name').value.trim();if(!name){showToast('Isi nama');return;}const tipe=document.getElementById('sosial-tipe').value;let item={tipe,name};if(tipe==='kontak'){item.relation=document.getElementById('sosial-relation')?.value||'';item.phone=document.getElementById('sosial-phone')?.value||'';item.birthday=document.getElementById('sosial-birthday')?.value||null;}else if(tipe==='hutang'){item.subtype=document.getElementById('sosial-subtype')?.value||'piutang';item.amount=parseInt(document.getElementById('sosial-amount')?.value)||0;item.due=document.getElementById('sosial-due')?.value||null;}else{item.occasion=document.getElementById('sosial-occasion')?.value||'';item.amount=parseInt(document.getElementById('sosial-gift-amount')?.value)||0;}const ei=document.getElementById('modal-sosial').dataset.editIdx;if(ei!==undefined)APP.sosial[parseInt(ei)]=item;else APP.sosial.push(item);save();closeModal('modal-sosial');showToast('Tersimpan');renderSosial(sosialTab);}
function deleteSosial(){const ei=document.getElementById('modal-sosial').dataset.editIdx;if(ei===undefined)return;if(!confirm('Hapus ini?'))return;APP.sosial.splice(parseInt(ei),1);save();closeModal('modal-sosial');showToast('Dihapus');renderSosial(sosialTab);}
function saveTrip(){const dest=document.getElementById('trip-dest').value.trim();if(!dest){showToast('Isi destinasi');return;}const item={dest,start:document.getElementById('trip-start').value||null,end:document.getElementById('trip-end').value||null,budget:parseInt(document.getElementById('trip-budget').value)||0,actual:parseInt(document.getElementById('trip-actual').value)||0,status:document.getElementById('trip-status').value};const ei=document.getElementById('modal-trip').dataset.editIdx;if(ei!==undefined)APP.trips[parseInt(ei)]=item;else APP.trips.push(item);save();closeModal('modal-trip');showToast('Trip tersimpan');renderTrip(tripFilter);}
function deleteTrip(){const ei=document.getElementById('modal-trip').dataset.editIdx;if(ei===undefined)return;if(!confirm('Hapus trip ini?'))return;APP.trips.splice(parseInt(ei),1);save();closeModal('modal-trip');showToast('Trip dihapus');renderTrip(tripFilter);}
function saveEnergi(){const amount=parseInt(document.getElementById('energi-amount').value);if(!amount){showToast('Isi nominal');return;}const item={jenis:document.getElementById('energi-jenis').value,bulan:document.getElementById('energi-bulan').value,amount};APP.energi.push(item);APP.transactions.push({desc:item.jenis,amount,type:'out',cat:'Kebutuhan Rumah',who:'Bersama',date:item.bulan+'-01'});save();closeModal('modal-energi');showToast('Utilitas tersimpan');renderEnergi();}
function saveEdu(){const name=document.getElementById('edu-name').value.trim();if(!name){showToast('Isi nama');return;}const biaya=parseInt(document.getElementById('edu-biaya').value)||0;const item={name,tipe:document.getElementById('edu-tipe').value,who:document.getElementById('edu-who').value,platform:document.getElementById('edu-platform').value,biaya,status:document.getElementById('edu-status').value};const ei=document.getElementById('modal-edu').dataset.editIdx;if(ei!==undefined)APP.pendidikan[parseInt(ei)]=item;else APP.pendidikan.push(item);if(biaya>0&&ei===undefined)APP.transactions.push({desc:name,amount:biaya,type:'out',cat:'Pendidikan',who:item.who,date:today()});save();closeModal('modal-edu');showToast('Tersimpan');renderEdu(eduFilter);}
function deleteEdu(){const ei=document.getElementById('modal-edu').dataset.editIdx;if(ei===undefined)return;if(!confirm('Hapus ini?'))return;APP.pendidikan.splice(parseInt(ei),1);save();closeModal('modal-edu');showToast('Dihapus');renderEdu(eduFilter);}
function saveProp(){const name=document.getElementById('prop-name').value.trim();if(!name){showToast('Isi nama');return;}const value=parseInt(document.getElementById('prop-value').value)||0;const item={tipe:document.getElementById('prop-tipe').value,name,value,date:document.getElementById('prop-date').value||null,note:document.getElementById('prop-note').value};const ei=document.getElementById('modal-properti').dataset.editIdx;if(ei!==undefined)APP.properti[parseInt(ei)]=item;else APP.properti.push(item);if(value>0&&item.tipe==='maintenance'&&ei===undefined)APP.transactions.push({desc:'Maintenance: '+name,amount:value,type:'out',cat:'Kebutuhan Rumah',who:'Bersama',date:item.date||today()});save();closeModal('modal-properti');showToast('Tersimpan');renderProperti();}
function deleteProp(){const ei=document.getElementById('modal-properti').dataset.editIdx;if(ei===undefined)return;if(!confirm('Hapus ini?'))return;APP.properti.splice(parseInt(ei),1);save();closeModal('modal-properti');showToast('Dihapus');renderProperti();}

// ============================================================
// FAB
// ============================================================
function toggleFab(){document.getElementById('fab-overlay').classList.toggle('active');}
function closeFab(){document.getElementById('fab-overlay').classList.remove('active');}

// ============================================================
// TOAST
// ============================================================
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2500);}

// ============================================================
// EXPORT / IMPORT
// ============================================================
function copyExport(){const t=document.getElementById('export-text').value;navigator.clipboard.writeText(t).then(()=>showToast('Data berhasil dicopy!')).catch(()=>showToast('Coba copy manual'));}
function importData(){try{const raw=document.getElementById('import-text').value.trim();const parsed=JSON.parse(raw);APP=parsed;['kendaraan','servis','inventaris','kesehatan','dokumen','todos','goals','sosial','trips','energi','pendidikan','properti'].forEach(k=>{if(!APP[k])APP[k]=[];});
if(!APP.belanjaLog) APP.belanjaLog = [];save();closeModal('modal-import');showToast('Data berhasil diimport!');updateNameOptions();navigate('home');}catch(e){showToast('Data tidak valid. Cek format JSON.');}}
function resetApp(){
  if(!confirm('Yakin mau reset semua data? Ini tidak bisa dibatalkan.'))return;
  localStorage.removeItem(SK);
  // Also clear Supabase
  fetch(`${SB_URL}/rest/v1/homeos_data`, {
    method:'POST',
    headers:{...SB_HEADERS,'Prefer':'resolution=merge-duplicates'},
    body: JSON.stringify({id:'main', data:{}, updated_at: new Date().toISOString()})
  }).finally(()=>location.reload());
}

// ============================================================
// MODAL CLOSE ON OVERLAY
// ============================================================
document.querySelectorAll('.modal-overlay').forEach(o=>{o.addEventListener('click',function(e){if(e.target===this)this.classList.remove('active');});});

// ============================================================
// INIT
// ============================================================
window.addEventListener('DOMContentLoaded', async ()=>{
  showLoadingScreen(true);
  // Safety net: loading screen ALWAYS dismisses after 6s max
  const safetyTimer = setTimeout(()=>{
    showLoadingScreen(false);
    if(document.getElementById('app').style.display === 'none') launchApp();
  }, 6000);

  try {
    // Try Supabase first (5s timeout)
    const cloudData = await loadFromSupabase();
    if(cloudData && cloudData.profile && cloudData.profile.name1){
      APP = cloudData;
      APP._lastSaved = Date.now();
      ['kendaraan','servis','inventaris','kesehatan','dokumen','todos','goals','sosial','trips','energi','pendidikan','properti'].forEach(k=>{if(!APP[k])APP[k]=[];});
      if(!APP.belanjaLog) APP.belanjaLog = [];
      localStorage.setItem(SK, JSON.stringify(APP));
      clearTimeout(safetyTimer);
      showLoadingScreen(false);
      launchApp();
      return;
    }
  } catch(e){ console.warn('Init cloud error:', e); }

  // Fallback: localStorage
  try {
    const existing = load();
    if(existing && existing.profile && existing.profile.name1){
      APP = existing;
      ['kendaraan','servis','inventaris','kesehatan','dokumen','todos','goals','sosial','trips','energi','pendidikan','properti'].forEach(k=>{if(!APP[k])APP[k]=[];});
      if(!APP.belanjaLog) APP.belanjaLog = [];
      clearTimeout(safetyTimer);
      showLoadingScreen(false);
      launchApp();
      return;
    }
  } catch(e){ console.warn('Init local error:', e); }

  // No data — fresh start
  clearTimeout(safetyTimer);
  showLoadingScreen(false);
  launchApp();
});

function showLoadingScreen(show){
  let el = document.getElementById('loading-screen');
  if(!el) return;
  el.style.display = show ? 'flex' : 'none';
}
