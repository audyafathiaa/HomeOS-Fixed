function renderMenu(){
  const el=document.getElementById('menu-grid-content');
  el.innerHTML=MENU_ITEMS.map(sec=>`
    <div class="menu-section-lbl">${sec.section}</div>
    <div class="menu-grid">${sec.items.map(item=>`
      <button class="menu-card" onclick="navigate('${item.id}')">
        <div class="menu-icon" style="background:${item.bg};"><svg viewBox="0 0 24 24" fill="none" stroke="${item.stroke}" stroke-width="2">${item.icon}</svg></div>
        <h4>${item.title}</h4><p>${item.desc}</p>
        <span class="mbadge ${item.badgeCls}">${item.badge()}</span>
      </button>`).join('')}
    </div>`).join('');
}
function filterMenu(q){
  if(!q){renderMenu();return;}
  const el=document.getElementById('menu-grid-content');
  const all=MENU_ITEMS.flatMap(s=>s.items);
  const filtered=all.filter(i=>i.title.toLowerCase().includes(q.toLowerCase())||i.desc.toLowerCase().includes(q.toLowerCase()));
  el.innerHTML=`<div class="menu-grid">${filtered.map(item=>`<button class="menu-card" onclick="navigate('${item.id}')"><div class="menu-icon" style="background:${item.bg};"><svg viewBox="0 0 24 24" fill="none" stroke="${item.stroke}" stroke-width="2">${item.icon}</svg></div><h4>${item.title}</h4><p>${item.desc}</p></button>`).join('')}</div>`;
}

