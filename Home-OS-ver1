        </div>
        <div style="width:90px;"><label class="batch-label">Merk</label>
          <input class="batch-input" value="${r.brand}" placeholder="Rojolele" oninput="updateBatchRow(${i},'brand',this.value)">
        </div>
        <button class="batch-del" onclick="deleteBatchRow(${i})"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
      </div>
      <div class="batch-row-bot">
        <div><label class="batch-label">Jumlah</label><input class="batch-input" type="number" value="${r.jumlah}" placeholder="2" oninput="updateBatchRow(${i},'jumlah',this.value)"></div>
        <div><label class="batch-label">Satuan</label><input class="batch-input" value="${r.satuan}" placeholder="kg, pcs, btl" oninput="updateBatchRow(${i},'satuan',this.value)"></div>
        <div><label class="batch-label">Expired</label><input class="batch-input" type="date" value="${r.expired}" oninput="updateBatchRow(${i},'expired',this.value)"></div>
        <div><label class="batch-label">Harga (Rp)</label><input class="batch-input" type="number" value="${r.harga}" placeholder="45000" oninput="updateBatchRow(${i},'harga',this.value);updateBatchTotal()"></div>
      </div>
    </div>
  `).join('');
