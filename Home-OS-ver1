function renderTimeline(){
  const events=[];
  APP.transactions.forEach(t=>events.push({date:t.date,title:t.desc,sub:t.cat+' · '+t.who,amount:(t.type==='out'?'-':'+')+fRp(t.amount),col:t.type==='out'?'var(--accent-red)':'var(--accent-green)',dot:'var(--primary)'}));
  APP.chores.filter(c=>c.lastDone).forEach(c=>events.push({date:c.lastDone,title:c.name,sub:'Chores · '+c.freq,amount:null,col:'var(--accent-green)',dot:'var(--accent-green)'}));
  APP.servis.forEach(s=>{const k=APP.kendaraan[s.kendIdx];events.push({date:s.date,title:s.tipe+(k?' — '+k.name:''),sub:'Kendaraan',amount:s.amount>0?'-'+fRp(s.amount):null,col:'var(--accent-orange)',dot:'var(--accent-orange)'});});
  APP.kesehatan.forEach(k=>events.push({date:k.date,title:k.name,sub:'Kesehatan · '+k.who,amount:k.biaya>0?'-'+fRp(k.biaya):null,col:'var(--accent-red)',dot:'#5CAEE0'}));
  events.sort((a,b)=>new Date(b.date)-new Date(a.date));
  const el=document.getElementById('timeline-list');
  if(events.length===0){el.innerHTML='<div class="empty-state"><p>Belum ada aktivitas tercatat.</p></div>';return;}
  el.innerHTML=events.slice(0,50).map((e,i)=>`<div class="timeline-item"><div class="tl-dot-wrap"><div class="tl-dot" style="background:${e.dot};"></div>${i<events.length-1?'<div class="tl-line"></div>':''}</div><div class="tl-info" style="flex:1;min-width:0;"><h4>${e.title}</h4><p>${e.sub}</p></div><div class="tl-right"><div class="tl-date">${fDateShort(e.date)}</div>${e.amount?`<div class="tl-amount" style="color:${e.col};">${e.amount}</div>`:''}</div></div>`).join('');
}

