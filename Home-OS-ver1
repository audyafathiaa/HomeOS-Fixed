function renderGroceryList(){
  const el = document.getElementById('grocery-list');
  const mode = gMode;

  // SEARCH MODE — override everything
  if(grocSearchQuery && grocSearchQuery.length >= 1){
    renderGrocerySearch(el);
    return;
  }

  if(mode === 'beli'){
    // Show only "beli" items grouped
    const beliItems = APP.groceries.filter(g => g.status === 'beli');
    if(beliItems.length === 0){
      el.innerHTML = `<div class="empty-state"><p>Belum ada item yang ditandai "Beli".</p></div>`;
      return;
    }
    const groups = {};
    beliItems.forEach(g=>{
      const cat = g.masterCat || g.cat || 'Lainnya';
      if(!groups[cat]) groups[cat]=[];
      groups[cat].push(g);
    });
    let html = '';
    Object.keys(groups).forEach(cat=>{
      html += `<div class="groc-section">${cat}</div>`;
      groups[cat].forEach(g=>{
        const ri = APP.groceries.indexOf(g);
        html += grocItemHTML(g, ri);
      });
    });
    el.innerHTML = html;
    return;
  }

  // DAFTAR MODE — show master list merged with user data
  // Build combined list: master items + user-added custom items
  const cats = gCatFilter === 'semua' ? GROCERY_CAT_ORDER : [gCatFilter];
  let html = '';

  cats.forEach(cat => {
    const masterItems = GROCERY_MASTER[cat] || [];
    // Get user-added custom items for this cat
    const customItems = APP.groceries.filter(g => (g.masterCat === cat || g.cat === cat) && g.isCustom);
    
    if(masterItems.length === 0 && customItems.length === 0) return;

    html += `<div class="groc-section">${cat}</div>`;
    
    // Master items — check if user has status data
    masterItems.forEach(itemName => {
      const existing = APP.groceries.find(g => g.name === itemName && (g.masterCat === cat || (!g.masterCat && g.cat === cat) || (!g.masterCat && !g.cat)));
      if(existing){
        const ri = APP.groceries.indexOf(existing);
        html += grocItemHTML(existing, ri);
      } else {
        // Not yet in user data — render as neutral (no status)
        html += grocMasterItemHTML(itemName, cat);
      }
    });

    // Custom items
    customItems.forEach(g=>{
      const ri = APP.groceries.indexOf(g);
      html += grocItemHTML(g, ri);
    });
  });

  // Show custom items with no masterCat if showing 'semua'
  if(gCatFilter === 'semua'){
    const orphans = APP.groceries.filter(g => g.isCustom && !GROCERY_CAT_ORDER.includes(g.masterCat));
    if(orphans.length > 0){
      html += `<div class="groc-section">Lainnya (Custom)</div>`;
      orphans.forEach(g=>{
        html += grocItemHTML(g, APP.groceries.indexOf(g));
      });
    }
  }

  if(!html) html = `<div class="empty-state"><p>Tidak ada item di kategori ini.</p></div>`;
  el.innerHTML = html;
}

function grocMasterItemHTML(name, cat){
  // Item belum ada data — tap nama untuk isi detail, atau langsung Ada/Beli/Skip
  const safeN = name.replace(/'/g,"&#39;");
  const safeC = cat.replace(/'/g,"&#39;");
  return `<div class="groc-item groc-master" onclick="openGrocDetail('${safeN}', null, '${safeC}')">
    <div class="groc-dot" style="background:var(--border);"></div>
    <div class="groc-info" style="flex:1;min-width:0;"><h4>${name}</h4></div>
    <div class="groc-adas" onclick="event.stopPropagation()">
      <button class="gas-btn gas-ada" onclick="setMasterItemStatus('${safeN}','${safeC}','ada')">Ada</button>
      <button class="gas-btn gas-beli" onclick="setMasterItemStatus('${safeN}','${safeC}','beli')">Beli</button>
      <button class="gas-btn gas-skip" onclick="setMasterItemStatus('${safeN}','${safeC}','skip')">Skip</button>
    </div>
  </div>`;
}

function grocItemHTML(g, ri){
  const dotMap = {ada:'d-cukup',beli:'d-habis',skip:'',habis:'d-habis',hampir:'d-hampir',cukup:'d-cukup'};
  let st = g.status;
  if(st === 'cukup') st = 'ada';
  if(st === 'hampir') st = 'beli';
  const dot = dotMap[st] || '';
  const safeN = g.name.replace(/'/g,"&#39;");

  // Sub-info: merk · jumlah satuan · expired
  const parts = [];
  if(g.brand) parts.push(g.brand);
  if(g.jumlah) parts.push(g.jumlah + (g.satuan ? ' ' + g.satuan : ''));
  if(g.expired){
    const d = daysDiff(g.expired);
    const expTxt = d !== null && d <= 0 ? '<span style="color:var(--accent-red);">⚠ Expired</span>'
      : d !== null && d <= 30 ? '<span style="color:var(--accent-orange);">Exp '+fDateShort(g.expired)+'</span>'
      : 'Exp '+fDateShort(g.expired);
    parts.push(expTxt);
  }
  const subLine = parts.join(' · ');

  return '<div class="groc-item" onclick="openGrocDetail(\''+safeN+'\','+ri+')">'
    + '<div class="groc-dot '+dot+'"></div>'
    + '<div class="groc-info" style="flex:1;min-width:0;">'
    + '<h4>'+g.name+'</h4>'
    + (subLine ? '<p style="font-size:10px;color:var(--text-mid);">'+subLine+'</p>' : '')
    + '</div>'
    + '<div class="groc-adas" onclick="event.stopPropagation()">'
    + '<button class="gas-btn gas-ada '+(st==='ada'?'gas-ada-active':'')+'" onclick="setItemStatus('+ri+',\'ada\')">Ada</button>'
    + '<button class="gas-btn gas-beli '+(st==='beli'?'gas-beli-active':'')+'" onclick="setItemStatus('+ri+',\'beli\')">Beli</button>'
    + '<button class="gas-btn gas-skip '+(st==='skip'?'gas-skip-active':'')+'" onclick="setItemStatus('+ri+',\'skip\')">Skip</button>'
    + '</div>'
    + '</div>';
}


function renderGrocerySearch(el){
  const q = grocSearchQuery;
  let html = '';
  let totalFound = 0;

  // Search across ALL master categories
  GROCERY_CAT_ORDER.forEach(cat => {
    const masterItems = GROCERY_MASTER[cat] || [];
    const matched = masterItems.filter(name => name.toLowerCase().includes(q));
    
    if(matched.length > 0){
      html += `<div class="groc-section">${cat}</div>`;
      totalFound += matched.length;
      matched.forEach(itemName => {
        const existing = APP.groceries.find(g => g.name === itemName);
        if(existing){
          const ri = APP.groceries.indexOf(existing);
          html += grocItemHTML(existing, ri);
        } else {
          html += grocMasterItemHTML(itemName, cat);
        }
      });
    }
  });

  // Also search user custom items
  const customMatched = APP.groceries.filter(g => g.isCustom && g.name.toLowerCase().includes(q));
  if(customMatched.length > 0){
    html += `<div class="groc-section">Custom</div>`;
    totalFound += customMatched.length;
    customMatched.forEach(g => {
      html += grocItemHTML(g, APP.groceries.indexOf(g));
    });
  }

  if(totalFound === 0){
    html = `<div class="empty-state"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="44" height="44"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg><p>Tidak ada item "${q}" ditemukan.</p></div>`;
  } else {
    html = `<div style="font-size:11px;color:var(--text-mid);margin:8px 0 4px;">${totalFound} item ditemukan untuk "<strong style="color:var(--primary);">${q}</strong>"</div>` + html;
  }

  el.innerHTML = html;
}

function encodeItemId(name){ return name.replace(/[^a-zA-Z0-9]/g,'_'); }

function setMasterItemStatus(name, cat, status){
  // Find or create entry in APP.groceries
  let idx = APP.groceries.findIndex(g => g.name === name);
  if(idx >= 0){
    APP.groceries[idx].status = status;
  } else {
    APP.groceries.push({name, masterCat: cat, cat, status, brand:'', isCustom: false});
    idx = APP.groceries.length - 1;
  }
  save();
  renderGroceryList();
}

function setItemStatus(ri, status){
  if(APP.groceries[ri]) APP.groceries[ri].status = status;
  save();
  renderGroceryList();
}


