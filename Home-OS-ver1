}

function saveBatchBelanja(){
  const toko = document.getElementById('batch-toko').value.trim();
  const tanggal = document.getElementById('batch-tanggal').value || today();
  const validItems = batchRows.filter(r => r.name.trim());
  if(!toko){ showToast('Isi nama toko dulu'); return; }
  if(validItems.length === 0){ showToast('Minimal 1 barang'); return; }
  if(!APP.belanjaLog) APP.belanjaLog = [];
  const session = { id: Date.now(), toko, tanggal, items: validItems.map(r=>({...r})) };
  APP.belanjaLog.unshift(session);
  validItems.forEach(r=>{
    const name = r.name.trim();
    if(!name) return;
    let idx = APP.groceries.findIndex(g => g.name.toLowerCase() === name.toLowerCase());
    let cat = 'Lainnya';
    for(const [c, items] of Object.entries(GROCERY_MASTER)){
      if(items.map(x=>x.toLowerCase()).includes(name.toLowerCase())){ cat = c; break; }
    }
    const stockEntry = {name, cat, masterCat:cat, status:'ada', brand:r.brand||(idx>=0?APP.groceries[idx].brand:''), jumlah:r.jumlah, satuan:r.satuan, expired:r.expired, harga:r.harga, lastBeli:tanggal, isCustom:idx>=0?APP.groceries[idx].isCustom:false};
    if(idx >= 0){ APP.groceries[idx] = {...APP.groceries[idx], ...stockEntry}; }
    else { APP.groceries.push(stockEntry); }
  });
  const total = validItems.reduce((s,r) => s + (parseFloat(r.harga)||0), 0);
  if(total > 0) APP.transactions.push({desc:'Belanja '+toko, amount:total, type:'out', cat:'Groceries', who:'Bersama', date:tanggal});
  save();
  closeModal('modal-batch-belanja');
  showToast(`✓ ${validItems.length} item berhasil diinput!`);
  renderGroceries();
}

