let cFilter='semua';

function initDefaultChores(){
  // Only add defaults if chores array is empty
  if(APP.chores.length > 0) return;
  ['daily','weekly','monthly','yearly'].forEach(freq=>{
    (CHORES_DEFAULT[freq]||[]).forEach(c=>{
      APP.chores.push({name:c.name, freq, assign:c.assign, lastDone:null, overdue:false});
    });
  });
  save();
}

function renderChores(){
  initDefaultChores();
  const list = cFilter==='semua' ? APP.chores : APP.chores.filter(c=>c.freq===cFilter);
  const el = document.getElementById('chore-list');
  if(list.length===0){
    el.innerHTML=`<div class="empty-state"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg><p>Tidak ada chores dengan filter ini.</p></div>`;
    return;
  }
  // Group by freq if showing 'semua'
  if(cFilter === 'semua'){
    const groups = {daily:[],weekly:[],monthly:[],yearly:[]};
    list.forEach(c => { if(groups[c.freq]) groups[c.freq].push(c); else groups['daily'].push(c); });
    const freqLabels = {daily:'Harian',weekly:'Mingguan',monthly:'Bulanan',yearly:'Tahunan'};
    let html = '';
    ['daily','weekly','monthly','yearly'].forEach(freq=>{
      if(groups[freq].length === 0) return;
      // count done today
      const doneToday = groups[freq].filter(c=>c.lastDone&&new Date(c.lastDone).toDateString()===new Date().toDateString()).length;
      html += `<div style="display:flex;justify-content:space-between;align-items:center;margin:16px 0 8px;">
        <div class="groc-section" style="margin:0;">${freqLabels[freq]}</div>
        <span style="font-size:11px;font-weight:600;color:var(--accent-green);">${doneToday}/${groups[freq].length} done</span>
      </div>`;
      groups[freq].forEach(c => { html += choreItemHTML(c, APP.chores.indexOf(c), false); });
    });
    el.innerHTML = html;
  } else {
    el.innerHTML = list.map(c => choreItemHTML(c, APP.chores.indexOf(c), false)).join('');
  }
}

function choreItemHTML(c, ri, compact){
  const isDone = c.lastDone && new Date(c.lastDone).toDateString()===new Date().toDateString();
  const checkCls = isDone ? 'done' : c.overdue ? 'overdue' : '';
  const check = isDone ? '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>' : '';
  let stCls = isDone ? 'cs-done' : c.overdue ? 'cs-overdue' : 'cs-pending';
  let stTxt = isDone ? 'Done' : c.overdue ? 'Overdue' : 'Belum';
  const lastTxt = c.lastDone && !isDone ? `<div class="chore-detail">Terakhir: ${fDateShort(c.lastDone)}</div>` : '';
  const editBtn = compact ? '' : `<button onclick="event.stopPropagation();editChore(${ri})" style="background:none;border:none;cursor:pointer;padding:2px;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#B0B0C8" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>`;
  return `<div class="chore-item">
    <div class="chore-check ${checkCls}" onclick="toggleChore(${ri})">${check}</div>
    <div class="chore-info">
      <h4>${c.name}</h4>
      <p>${c.freq} · ${c.assign}</p>
      ${compact ? '' : lastTxt}
    </div>
    <div style="display:flex;align-items:center;gap:6px;">
      <span class="chore-status ${stCls}">${stTxt}</span>
      ${editBtn}
    </div>
  </div>`;
}

function filterChore(f, el){
  cFilter = f;
  document.querySelectorAll('#screen-chores .tab-btn').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  renderChores();
}

function toggleChore(i){
  const isDone = APP.chores[i].lastDone && new Date(APP.chores[i].lastDone).toDateString()===new Date().toDateString();
  if(isDone){ APP.chores[i].lastDone = null; }
  else { APP.chores[i].lastDone = new Date().toISOString(); APP.chores[i].overdue = false; }
  save(); renderChores();
  if(document.getElementById('screen-home').classList.contains('active')) renderHome();
}

