function openGrocDetail(name, ri, fallbackCat){
  grocDetailName = name;
  grocDetailRi   = ri !== null ? ri : null;

  // Find or create entry
  let g = ri !== null && ri !== undefined && APP.groceries[ri]
    ? APP.groceries[ri]
    : APP.groceries.find(x => x.name === name);

  // Header
  document.getElementById('stok-detail-name').textContent = name;
  const cat = g ? (g.masterCat || g.cat || '') : (fallbackCat || '');
  document.getElementById('stok-detail-cat').textContent = cat;

  // Status badge
  const statusMap = {
    ada:  {bg:'#E5F7EF',col:'#4CAF8C',lbl:'Ada'},
    beli: {bg:'#FFE5E5',col:'#E05C5C',lbl:'Perlu Beli'},
    skip: {bg:'var(--bg)',col:'var(--text-light)',lbl:'Skip'},
  };
  const st = g ? (g.status === 'cukup' ? 'ada' : g.status === 'hampir' ? 'beli' : g.status) : null;
  const sc = statusMap[st] || null;
  document.getElementById('stok-detail-status-badge').innerHTML = sc
    ? `<span style="font-size:11px;font-weight:700;padding:4px 12px;border-radius:20px;background:${sc.bg};color:${sc.col};">${sc.lbl}</span>`
    : '';

  // Fill form fields
  document.getElementById('sd-jumlah').value  = g && g.jumlah  ? g.jumlah  : '';
  document.getElementById('sd-satuan').value  = g && g.satuan  ? g.satuan  : '';
  document.getElementById('sd-brand').value   = g && g.brand   ? g.brand   : '';
  document.getElementById('sd-expired').value = g && g.expired ? g.expired : '';

  // Riwayat belanja
  if(!APP.belanjaLog) APP.belanjaLog = [];
  const history = [];
  APP.belanjaLog.forEach(session => {
    session.items.forEach(item => {
      if(item.name.toLowerCase() === name.toLowerCase()){
        history.push({toko: session.toko, tanggal: session.tanggal, ...item});
      }
    });
  });

  const histEl = document.getElementById('stok-detail-history');
  if(history.length === 0){
    histEl.innerHTML = `<div style="text-align:center;padding:16px 0;font-size:12px;color:var(--text-light);">Belum ada riwayat belanja untuk item ini.</div>`;
  } else {
    histEl.innerHTML = history.map(h => `
      <div class="stok-hist-item">
        <div class="stok-hist-top">
          <span class="stok-hist-toko">🛒 ${h.toko}</span>
          <span class="stok-hist-date">${fDateShort(h.tanggal)}</span>
        </div>
        <div class="stok-hist-row">
          ${h.brand   ? `<span>Merk: <strong>${h.brand}</strong></span>` : ''}
          ${h.jumlah  ? `<span>Jml: <strong>${h.jumlah} ${h.satuan||''}</strong></span>` : ''}
          ${h.harga   ? `<span>Harga: <strong>${fRp(h.harga)}</strong></span>` : ''}
          ${h.expired ? `<span>Exp: <strong>${fDateShort(h.expired)}</strong></span>` : ''}
        </div>
      </div>`).join('');
  }

  document.getElementById('modal-stok-detail').classList.add('active');
}

function saveStokDetail(){
  const name    = grocDetailName;
  const jumlah  = document.getElementById('sd-jumlah').value.trim();
  const satuan  = document.getElementById('sd-satuan').value.trim();
  const brand   = document.getElementById('sd-brand').value.trim();
  const expired = document.getElementById('sd-expired').value;

  if(!name) return;

  // Find or create entry in APP.groceries
  let idx = grocDetailRi !== null ? grocDetailRi
    : APP.groceries.findIndex(g => g.name === name);

  if(idx >= 0 && idx !== null){
    // Update existing
    APP.groceries[idx].jumlah  = jumlah;
    APP.groceries[idx].satuan  = satuan;
    APP.groceries[idx].brand   = brand;
    APP.groceries[idx].expired = expired || null;
    // If status was unset, mark as ada
    if(!APP.groceries[idx].status || APP.groceries[idx].status === 'unknown'){
      APP.groceries[idx].status = 'ada';
    }
  } else {
    // New entry (master item not yet touched)
    let cat = 'Lainnya';
    for(const [c, items] of Object.entries(GROCERY_MASTER)){
      if(items.map(x=>x.toLowerCase()).includes(name.toLowerCase())){ cat = c; break; }
    }
    APP.groceries.push({
      name, cat, masterCat: cat,
      status: 'ada',
      brand, jumlah, satuan,
      expired: expired || null,
      isCustom: false
    });
  }

  save();
  closeModal('modal-stok-detail');
  showToast('✓ Detail tersimpan');
  renderGroceryList();
}

